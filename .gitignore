# Virtual environments
venv/
.venv/
env/
ENV/

# Environment files — never commit secrets; .example templates are safe to commit
.env
.env.*
!.env.example
!.env.production.example

# Firebase secrets — service-account JSON gives full project access. NEVER commit. Live outside the repo at
# ~/firebase-admin-key.json; the value also goes into Railway env vars for production.
*firebase-adminsdk*.json
firebase-admin-key.json
# google-services.json is committed (it's a public-ish identifier, not a secret), but only at its proper path.
# The wildcard pattern below catches stray copies at the repo root from drag-and-drop accidents:
/google-services.json

# Caddy + Docker volume artefacts (production stack)
caddy_data/
caddy_config/

# Django collectstatic / uploads
backend/staticfiles/
backend/media/

# Python packaging
build/
dist/
*.egg-info/

# Flutter / Dart
mobile/.dart_tool/
mobile/.packages
mobile/.flutter-plugins
mobile/.flutter-plugins-dependencies
mobile/.metadata
mobile/build/
mobile/coverage/

# Flutter platform generated folders
mobile/android/.gradle/
mobile/android/app/debug/
mobile/android/app/profile/
mobile/android/app/release/

# Android signing — NEVER commit. Losing these = locked out of Play Store updates forever; keep a backup outside git.
mobile/android/key.properties
mobile/android/**/*.jks
mobile/android/**/*.keystore
mobile/ios/Pods/
mobile/ios/.symlinks/
mobile/ios/Flutter/Flutter.framework
mobile/ios/Flutter/Flutter.podspec
mobile/macos/Pods/

# Node (if later used for tools/web/admin)
node_modules/

# Docker
postgres_data/