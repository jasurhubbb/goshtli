DEBUG=True
SECRET_KEY=change-me-in-local-env
ALLOWED_HOSTS=127.0.0.1,localhost

DB_NAME=meat_marketplace
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=postgres
DB_PORT=5432

ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ----- Cloudflare R2 (production image storage) -----
# Leave R2_BUCKET blank in dev to use local filesystem (MEDIA_ROOT). Set ALL five vars in production.
# Setup: Cloudflare dashboard → R2 → Create bucket. Then "Manage R2 API tokens" → Create scoped to the bucket.
R2_BUCKET=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Public URL prefix served to mobile clients. Cloudflare gives you a pub-xxx.r2.dev by default; in production
# point it at a custom domain bound to your bucket (e.g. https://cdn.goshtli.uz).
R2_PUBLIC_URL=

# ----- Celery + Redis (async tasks) -----
# Broker for the image-resize worker. docker-compose's `redis` service listens on this host inside the network;
# bare-metal dev pointing at a host-installed Redis would use redis://localhost:6379/0 instead.
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0