# Production env template — copy to .env on the deploy host and fill in real values. NEVER commit .env.
# Generate SECRET_KEY via: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

DEBUG=False
SECRET_KEY=change-me-to-random-50-char-string
ALLOWED_HOSTS=api.yourdomain.com

# Postgres — use the host's managed Postgres if available; for compose, point at the postgres service
DB_NAME=meat_marketplace
DB_USER=postgres
DB_PASSWORD=change-me-strong-password
DB_HOST=postgres
DB_PORT=5432

# JWT lifetimes — tighten ACCESS for prod if your refresh flow is reliable
ACCESS_TOKEN_LIFETIME_MINUTES=30
REFRESH_TOKEN_LIFETIME_DAYS=14

# Frontend origin(s) allowed to call the API — comma-separated, no trailing slashes
CORS_ALLOWED_ORIGINS=https://app.yourdomain.com,https://www.yourdomain.com
