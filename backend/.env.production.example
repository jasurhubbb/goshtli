# Production env template — copy to .env on the deploy host and fill in real values. NEVER commit .env.
# Generate SECRET_KEY via: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

DEBUG=False
SECRET_KEY=change-me-to-random-50-char-string
ALLOWED_HOSTS=api.yourdomain.com

# Postgres — use the host's managed Postgres if available; for compose, point at the postgres service
DB_NAME=meat_marketplace
DB_USER=postgres
DB_PASSWORD=change-me-strong-password
DB_HOST=postgres
DB_PORT=5432

# JWT lifetimes — tighten ACCESS for prod if your refresh flow is reliable
ACCESS_TOKEN_LIFETIME_MINUTES=30
REFRESH_TOKEN_LIFETIME_DAYS=14

# Frontend origin(s) allowed to call the API — comma-separated, no trailing slashes
CORS_ALLOWED_ORIGINS=https://app.yourdomain.com,https://www.yourdomain.com

# ----- Cloudflare R2 (image storage) -----
# REQUIRED in production. R2_BUCKET being set switches Django to S3-compatible storage automatically.
# Setup steps in Cloudflare dashboard:
#   1. R2 → Create bucket (name it goshtli-prod or similar; record this)
#   2. R2 → Manage R2 API tokens → Create token with "Object Read & Write" scoped to this bucket
#   3. Bucket → Settings → "Public access" → Allow public via R2.dev or attach a custom domain
R2_BUCKET=goshtli-prod
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_PUBLIC_URL=https://pub-xxxxxxxxxx.r2.dev

# ----- Celery + Redis (async tasks) -----
# In production point at a managed Redis (Upstash, Railway Redis, AWS ElastiCache) — managed = backups + failover.
# Self-hosting Redis in the same VPC is fine for v1 but you take on the ops burden of memory + persistence tuning.
CELERY_BROKER_URL=redis://your-redis-host:6379/0
CELERY_RESULT_BACKEND=redis://your-redis-host:6379/0
